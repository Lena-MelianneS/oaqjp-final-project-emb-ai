import unittest
from emotion_detection import emotion_detector

class Test_Emotion(unittest.TestCase):
    #joy
    def test_emotion_detector(self):
        emotion = emotion_detector(" I am glad this happened")
        emotion = list(emotion.values())[5]
        self.assertEqual(emotion, 'joy')
        print (f"Correct ! The answer is indeed '{emotion}'")

